@page
@model AgregarModel
@{
    ViewData["Title"] = "Agregar producto";
}

<header class="subhead">
    <div class="container">
        <div class="masthead-subheading">SC-701: Programacion Web Avanzada</div>
        <div class="masthead-heading text-uppercase">Registrar producto</div>
    </div>
</header>

<section class="page-section bg-light" id="principal">
    <div class="container">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">Agregar producto</h2>
            <h3 class="section-subheading text-muted">Formulario adaptado al contrato de Producto.API.</h3>
        </div>

        <div class="col-xl-7 col-lg-8 col-md-10 mx-auto">
            <form method="post">
                <div class="form-group mb-3">
                    <label class="control-label" asp-for="Producto.IdCategoria"></label>
                    <select class="form-select" asp-for="Producto.IdCategoria" asp-items="Model.Categorias" id="categorias" onchange="fetchSubCategorias()">
                        <option value="">Seleccione una categoria</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Producto.IdCategoria"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label" asp-for="Producto.IdSubCategoria"></label>
                    <select class="form-select" asp-for="Producto.IdSubCategoria" asp-items="Model.SubCategorias" id="subcategorias">
                        <option value="">Seleccione una subcategoria</option>
                    </select>
                    <span class="text-danger" asp-validation-for="Producto.IdSubCategoria"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label" asp-for="Producto.Nombre"></label>
                    <input class="form-control" asp-for="Producto.Nombre" />
                    <span class="text-danger" asp-validation-for="Producto.Nombre"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label" asp-for="Producto.Descripcion"></label>
                    <textarea class="form-control" asp-for="Producto.Descripcion" rows="4"></textarea>
                    <span class="text-danger" asp-validation-for="Producto.Descripcion"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label" asp-for="Producto.Precio"></label>
                    <input class="form-control" asp-for="Producto.Precio" type="number" step="0.01" />
                    <span class="text-danger" asp-validation-for="Producto.Precio"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label" asp-for="Producto.Stock"></label>
                    <input class="form-control" asp-for="Producto.Stock" type="number" step="1" />
                    <span class="text-danger" asp-validation-for="Producto.Stock"></span>
                </div>
                <div class="form-group mb-3">
                    <label class="control-label" asp-for="Producto.CodigoBarras"></label>
                    <input class="form-control" asp-for="Producto.CodigoBarras" />
                    <span class="text-danger" asp-validation-for="Producto.CodigoBarras"></span>
                </div>
                <div class="text-danger mb-3" asp-validation-summary="All"></div>
                <div class="form-group">
                    <a class="btn btn-primary" asp-page="./Index">Regresar</a>
                    <input type="submit" value="Agregar" class="btn btn-success" />
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        async function fetchSubCategorias() {
            const categoriaId = document.getElementById('categorias').value;
            const subCategoriasSelect = document.getElementById('subcategorias');

            subCategoriasSelect.innerHTML = '<option value="">Seleccione una subcategoria</option>';

            if (!categoriaId) {
                return;
            }

            const response = await fetch(`?handler=ObtenerSubCategorias&categoriaId=${categoriaId}`);
            if (!response.ok) {
                return;
            }

            const subCategorias = await response.json();
            subCategorias.forEach(subCategoria => {
                const option = document.createElement('option');
                option.value = subCategoria.id;
                option.text = subCategoria.nombre;
                subCategoriasSelect.appendChild(option);
            });
        }
    </script>
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
