@page
@model IndexModel
@{
    ViewData["Title"] = "Productos";
}

<header class="subhead">
    <div class="container">
        <div class="masthead-subheading">SC-701: Programación Web Avanzada</div>
        <div class="masthead-heading text-uppercase">Listado de productos</div>
    </div>
</header>

<section class="page-section bg-light" id="principal">
    <div class="container">
        <div class="text-center">
            <h2 class="section-heading text-uppercase">Productos</h2>
            <h3 class="section-subheading text-muted">Frontend Razor Pages consumiendo Producto.API.</h3>
        </div>
        <div class="text-center mb-4">
            <a type="button" class="btn btn-group-lg btn-success btn-lg" asp-page="./Agregar">
                <i class="bi bi-plus-square"></i> Agregar producto
            </a>
        </div>

        @if (Model.Productos.Count == 0)
        {
            <div class="alert alert-warning" role="alert">
                No hay productos disponibles.
            </div>
        }
        else
        {
            <div class="row">
                @foreach (var producto in Model.Productos)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card h-100 shadow-sm">
                            <div class="card-body">
                                <h5 class="card-title">
                                    <i class="bi bi-box-seam"></i> @producto.Nombre
                                </h5>
                                <h6 class="card-subtitle mb-2 text-muted">@producto.Categoria / @producto.SubCategoria</h6>
                                <p class="card-text mb-1"><strong>Stock:</strong> @producto.Stock</p>
                                <p class="card-text mb-1"><strong>Precio CRC:</strong> @producto.Precio.ToString("N2")</p>
                                <p class="card-text"><strong>Precio USD:</strong> @producto.PrecioUSD.ToString("N2")</p>
                                <a type="button" class="btn btn-primary" asp-page="./Detalle" asp-route-id="@producto.Id">
                                    <i class="bi bi-info-square"></i> Detalle
                                </a>
                                <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@producto.Id">
                                    <i class="bi bi-pencil-square"></i> Editar
                                </a>
                                <a type="button" class="btn btn-danger" asp-page="./Eliminar" asp-route-id="@producto.Id">
                                    <i class="bi bi-trash3-fill"></i> Eliminar
                                </a>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</section>
